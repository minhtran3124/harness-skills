{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "hooks/check-untracked-py.sh",
            "statusMessage": "Checking untracked .py before git…"
          },
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "hooks/commit-quality-gate.sh",
            "statusMessage": "Commit quality gate (secrets, debug, tests)…"
          },
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "hooks/risk-corroboration.sh",
            "statusMessage": "Risk corroboration (diff vs declared lane)…"
          },
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "hooks/branch-guard.sh",
            "statusMessage": "Branch guard (warn on main)…"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/ruff-on-edit.sh",
            "statusMessage": "ruff --fix on edited .py…"
          },
          {
            "type": "command",
            "command": "hooks/blast-radius-check.sh",
            "statusMessage": "Blast-radius check (edit vs active plan)…"
          },
          {
            "type": "command",
            "command": "hooks/render-plan-on-write.sh",
            "statusMessage": "Auto-render PLAN.html…"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "hooks/scope-gate.sh",
            "statusMessage": "Scope-gate check…"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "hooks/state-breadcrumb.sh",
            "statusMessage": "Writing session breadcrumb to specs/STATE.md…"
          }
        ]
      }
    ]
  }
}
