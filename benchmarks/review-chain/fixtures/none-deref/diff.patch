@@ -0,0 +1,23 @@
+from fastapi import APIRouter, Depends
+
+from app.database import get_db
+from app.dependencies import get_current_user
+from app.repositories.user_repository import UserRepository
+from app.schemas.user import UserEmailResponse
+
+router = APIRouter(prefix="/users", tags=["users"])
+
+
+@router.get(
+    "/{user_id}/email",
+    response_model=UserEmailResponse,
+    dependencies=[Depends(get_current_user)],
+)
+async def get_user_email(user_id: str, db=Depends(get_db)) -> UserEmailResponse:
+    repo = UserRepository(db)
+    user = await repo.get_by_id(user_id)
+    return UserEmailResponse(email=user.email)
+
+
+# UserRepository extends BaseRepository; get_by_id returns Optional[User]
+# (None when the id is absent or soft-deleted).
